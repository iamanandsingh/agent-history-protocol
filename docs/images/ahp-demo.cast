[8.637105, "o", "AHP вЂ” Agent History Protocol CLI\r\n\r\nCommands:\r\n  ahp log    [--chain FILE] [--last N]             Show records\r\n             [--authorized-by ID] [--unauthorized]\r\n  ahp show   <seq> [--chain FILE] [--tree]         Show record details\r\n  ahp verify [--chain FILE] [--witness]            Verify chain integrity\r\n  ahp export [--chain FILE]                        Export as JSON\r\n  ahp trace  <session_id_prefix> [--chain FILE]    Trace session decisions\r\n  ahp gaps   [--chain FILE]                        List gap records\r\n  ahp init   [<agent_name>]                        Setup wizard\r\n  ahp keygen                                       Generate Ed25519 keypair\r\n  ahp viewer [--chain FILE] [PORT]                 Open web viewer\r\n"]
[10.158768, "o", "\r\n"]
[10.158881, "o", "\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n\u001b[1m  PART 2: Run Multi-Agent System with Real LLM\u001b[0m\r\n\u001b[1mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\u001b[0m\r\n"]
